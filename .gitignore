```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies and build directories
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs and coverage
*.log
coverage/
htmlcov/
.coverage

# Build artifacts
dist/
build/
target/
.gradle/

# Cache directories
.mypy_cache/
.pytest_cache/
```